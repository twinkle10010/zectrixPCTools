{
  "applicationId": "com.zectrix.pctools",
  "version": "1.0.0",
  "defaultMode": "window",
  "port": 0,
  "documentRoot": "/dist/",
  "url": "/index.html",
  "enableServer": true,
  "enableNativeAPI": true,
  "enableInspector": true,
  "enableExtensions": true,
  "extensions": [
    {
      "id": "hotkey.ext",
      "command": "extensions/hotkey/hotkey-ext.exe",
      "commandWindows": "extensions/hotkey/hotkey-ext.exe"
    }
  ],
  "modes": {
    "window": {
      "title": "zectrixPCTools",
      "icon": "icon.png",
      "width": 700,
      "height": 900,
      "minWidth": 700,
      "minHeight": 900,
      "resizable": true,
      "center": true,
      "alwaysOnTop": true,
      "borderless": true,
      "transparent": true,
      "background": "#1a1a2e"
    }
  },
  "cli": {
    "binaryName": "zectrixPCTools",
    "resourcesPath": "dist",
    "distributionPath": "dist",
    "binaryVersion": "6.7.0",
    "applicationIcon": "icon.png",
    "copyItems": [
      "icon.ico",
      "icon.png",
      "extensions"
    ]
  }
}
